# SQL/PGQ: ALL SHORTEST path mode

# ===================================================================
# Setup: diamond graph A->B->D, A->C->D (two shortest paths)
# ===================================================================

statement ok
CREATE TABLE as_nodes (id INTEGER, name VARCHAR)

statement ok
INSERT INTO as_nodes VALUES (0, 'A'), (1, 'B'), (2, 'C'), (3, 'D')

statement ok
CREATE TABLE as_edges (src INTEGER, dst INTEGER)

statement ok
INSERT INTO as_edges VALUES (0, 1), (0, 2), (1, 3), (2, 3)

statement ok
CREATE PROPERTY GRAPH as_graph VERTEX TABLES (as_nodes LABEL Node) EDGE TABLES (as_edges SOURCE KEY (src) REFERENCES as_nodes (id) DESTINATION KEY (dst) REFERENCES as_nodes (id) LABEL Edge)

# ===================================================================
# ALL SHORTEST returns both paths through diamond
# ===================================================================

query TT
SELECT * FROM GRAPH_TABLE (as_graph MATCH p = ALL SHORTEST (a:Node WHERE a.name = 'A')-[e:Edge]->{1,3}(b:Node WHERE b.name = 'D') COLUMNS (vertices(p) AS verts, edges(p) AS edgs)) ORDER BY verts
----
[0, 1, 3] [(0, 1), (1, 3)]
[0, 1, 3] [(0, 1), (1, 3)]
[0, 1, 3] [(0, 1), (1, 3)]
[0, 2, 3] [(0, 2), (2, 3)]
[0, 2, 3] [(0, 2), (2, 3)]
[0, 2, 3] [(0, 2), (2, 3)]

# ===================================================================
# ALL SHORTEST with single path (no branching)
# ===================================================================

query TT
SELECT * FROM GRAPH_TABLE (as_graph MATCH p = ALL SHORTEST (a:Node WHERE a.name = 'A')-[e:Edge]->{1,3}(b:Node WHERE b.name = 'B') COLUMNS (vertices(p) AS verts, edges(p) AS edgs))
----
[0, 1] [(0, 1)]
[0, 1] [(0, 1)]

# ===================================================================
# ALL SHORTEST with no path
# ===================================================================

query TT
SELECT * FROM GRAPH_TABLE (as_graph MATCH p = ALL SHORTEST (a:Node WHERE a.name = 'D')-[e:Edge]->{1,3}(b:Node WHERE b.name = 'A') COLUMNS (vertices(p) AS verts, edges(p) AS edgs))
----

# ===================================================================
# Cleanup
# ===================================================================

statement ok
DROP TABLE as_nodes

statement ok
DROP TABLE as_edges
