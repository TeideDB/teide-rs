# SQL/PGQ: Multi-hop fixed patterns

# Setup: Person -[Knows]-> Person -[LivesIn]-> City
statement ok
CREATE TABLE mh_persons (id INTEGER, name VARCHAR)

statement ok
INSERT INTO mh_persons VALUES (0, 'Alice'), (1, 'Bob'), (2, 'Carol')

statement ok
CREATE TABLE mh_cities (id INTEGER, city VARCHAR)

statement ok
INSERT INTO mh_cities VALUES (0, 'NYC'), (1, 'SF')

statement ok
CREATE TABLE mh_knows (src INTEGER, dst INTEGER)

statement ok
INSERT INTO mh_knows VALUES (0, 1), (0, 2), (1, 2)

statement ok
CREATE TABLE mh_lives (person_id INTEGER, city_id INTEGER)

statement ok
INSERT INTO mh_lives VALUES (0, 0), (1, 1), (2, 0)

statement ok
CREATE PROPERTY GRAPH mh_graph VERTEX TABLES (mh_persons LABEL Person, mh_cities LABEL City) EDGE TABLES (mh_knows SOURCE KEY (src) REFERENCES mh_persons (id) DESTINATION KEY (dst) REFERENCES mh_persons (id) LABEL Knows, mh_lives SOURCE KEY (person_id) REFERENCES mh_persons (id) DESTINATION KEY (city_id) REFERENCES mh_cities (id) LABEL LivesIn)

# 2-hop: Alice knows someone who lives in a city
query TT
SELECT * FROM GRAPH_TABLE (mh_graph MATCH (a:Person WHERE a.name = 'Alice')-[:Knows]->(b:Person)-[:LivesIn]->(c:City) COLUMNS (b.name, c.city)) ORDER BY b.name
----
Bob SF
Carol NYC

# --- Variable-length multi-hop ---

# Setup: financial graph
# Person -[Owns]-> Account -[Transfer]->+ Account
statement ok
CREATE TABLE fin_persons (id INTEGER, name VARCHAR)

statement ok
INSERT INTO fin_persons VALUES (0, 'Alice'), (1, 'Bob')

statement ok
CREATE TABLE fin_accounts (id INTEGER, acct_name VARCHAR)

statement ok
INSERT INTO fin_accounts VALUES (0, 'Checking_A'), (1, 'Savings_A'), (2, 'Checking_B')

statement ok
CREATE TABLE fin_owns (person_id INTEGER, account_id INTEGER)

statement ok
INSERT INTO fin_owns VALUES (0, 0), (0, 1), (1, 2)

statement ok
CREATE TABLE fin_transfers (src_acct INTEGER, dst_acct INTEGER)

statement ok
INSERT INTO fin_transfers VALUES (0, 2), (2, 1)

statement ok
CREATE PROPERTY GRAPH fin_graph VERTEX TABLES (fin_persons LABEL Person, fin_accounts LABEL Account) EDGE TABLES (fin_owns SOURCE KEY (person_id) REFERENCES fin_persons (id) DESTINATION KEY (account_id) REFERENCES fin_accounts (id) LABEL Owns, fin_transfers SOURCE KEY (src_acct) REFERENCES fin_accounts (id) DESTINATION KEY (dst_acct) REFERENCES fin_accounts (id) LABEL Transfer)

# Multi-hop: Alice's accounts that transferred to any account in 1+ hops
query TT
SELECT * FROM GRAPH_TABLE (fin_graph MATCH (p:Person WHERE p.name = 'Alice')-[:Owns]->(a1:Account)-[:Transfer]->+(a2:Account) COLUMNS (a1.acct_name, a2.acct_name)) ORDER BY 1, 2
----
Checking_A Checking_B
Checking_A Savings_A

# --- Cyclic variable binding ---

# Triangle detection: (p:Person)-[e1:Knows]->(q:Person)-[e2:Knows]->(r:Person)-[e3:Knows]->(p:Person)
# Using existing mh_graph: Alice→Bob, Alice→Carol, Bob→Carol (no back edges so no triangles)

# First, add back-edges to create a triangle: Bob→Alice and Carol→Bob
statement ok
CREATE TABLE mh_knows2 (src INTEGER, dst INTEGER)

statement ok
INSERT INTO mh_knows2 VALUES (0, 1), (0, 2), (1, 2), (1, 0), (2, 0)

statement ok
CREATE TABLE mh_persons2 (id INTEGER, name VARCHAR)

statement ok
INSERT INTO mh_persons2 VALUES (0, 'Alice'), (1, 'Bob'), (2, 'Carol')

statement ok
CREATE PROPERTY GRAPH cycle_graph VERTEX TABLES (mh_persons2 LABEL Person) EDGE TABLES (mh_knows2 SOURCE KEY (src) REFERENCES mh_persons2 (id) DESTINATION KEY (dst) REFERENCES mh_persons2 (id) LABEL Knows)

# Cyclic 3-hop: (p)-[Knows]->(q)-[Knows]->(r)-[Knows]->(p) starting from Alice
# Alice→Bob→Carol→Alice is a valid cycle
query TTT
SELECT * FROM GRAPH_TABLE (cycle_graph MATCH (p:Person WHERE p.name = 'Alice')-[:Knows]->(q:Person)-[:Knows]->(r:Person)-[:Knows]->(p:Person) COLUMNS (p.name AS p, q.name AS q, r.name AS r)) ORDER BY 2, 3
----
Alice Bob Carol

# Variable-length cycle: find all 2-to-3 hop cycles from Alice back to Alice
# 2-hop: Alice→Bob→Alice, Alice→Carol→Alice
# 3-hop: Alice→Bob→Carol→Alice
query TI
SELECT * FROM GRAPH_TABLE (cycle_graph MATCH (p:Person WHERE p.name = 'Alice')-[:Knows]->{2,3}(p:Person) COLUMNS (p.name AS pname, path_length(p, p) AS hops)) ORDER BY 2
----
Alice 2
Alice 2
Alice 3

# --- ANY SHORTEST with multi-edge patterns ---

# ANY SHORTEST multi-hop: find shortest 2-edge path from Alice through Knows then LivesIn
# Using original mh_graph: Alice(0)→Bob(1), Alice(0)→Carol(2), Bob(1)→Carol(2)
# LivesIn: Alice→NYC(0), Bob→SF(1), Carol→NYC(0)
# Paths from Alice: Alice→Bob→SF, Alice→Carol→NYC (both depth 2, shortest possible)
query TTT
SELECT * FROM GRAPH_TABLE (mh_graph MATCH path = ANY SHORTEST (a:Person WHERE a.name = 'Alice')-[:Knows]->(b:Person)-[:LivesIn]->(c:City) COLUMNS (a.name AS a, b.name AS b, c.city AS c)) ORDER BY 2
----
Alice Bob SF
Alice Carol NYC

# ANY SHORTEST with variable-length: find shortest transfer chain from Alice's account
# Shortest chain: Checking_A → Checking_B (1 hop via Transfer, total depth 2 with Owns)
query TTI
SELECT * FROM GRAPH_TABLE (fin_graph MATCH path = ANY SHORTEST (p:Person WHERE p.name = 'Alice')-[:Owns]->(a1:Account)-[:Transfer]->+(a2:Account) COLUMNS (p.name AS p, a1.acct_name AS a1, path_length(p, a2) AS hops)) ORDER BY 2
----
Alice Checking_A 2

# --- Cross-table traversal ---

# 3-segment forward: Person -[Owns]-> Account -[Transfer]-> Account (all results)
# Alice owns Checking_A(0), Savings_A(1); Bob owns Checking_B(2)
# Transfers: Checking_A(0)->Checking_B(2), Checking_B(2)->Savings_A(1)
# Alice's accounts: Checking_A → Transfer → Checking_B; Checking_A → Transfer → Checking_B → Transfer → Savings_A
query TTT
SELECT * FROM GRAPH_TABLE (fin_graph MATCH (p:Person WHERE p.name = 'Alice')-[:Owns]->(a1:Account)-[:Transfer]->+(a2:Account) COLUMNS (p.name AS person, a1.acct_name AS src_acct, a2.acct_name AS dst_acct)) ORDER BY 2, 3
----
Alice Checking_A Checking_B
Alice Checking_A Savings_A

# Reverse-edge traversal: Account <-[Owns]- Person
# Which person owns the account that received a transfer from Checking_A?
# Checking_A(0) -[Transfer]-> Checking_B(2) <-[Owns]- Bob(1)
query TTT
SELECT * FROM GRAPH_TABLE (fin_graph MATCH (a1:Account WHERE a1.acct_name = 'Checking_A')-[:Transfer]->(a2:Account)<-[:Owns]-(p:Person) COLUMNS (a1.acct_name AS src, a2.acct_name AS dst, p.name AS owner)) ORDER BY 2
----
Checking_A Checking_B Bob

# Mixed direction 3-segment: Person -[Owns]-> Account -[Transfer]-> Account <-[Owns]- Person
# "Who did Alice's money reach?" (through account transfers)
# Alice -[Owns]-> Checking_A -[Transfer]-> Checking_B <-[Owns]- Bob
query TT
SELECT * FROM GRAPH_TABLE (fin_graph MATCH (p1:Person WHERE p1.name = 'Alice')-[:Owns]->(a1:Account)-[:Transfer]->(a2:Account)<-[:Owns]-(p2:Person) COLUMNS (p1.name AS sender, p2.name AS receiver)) ORDER BY 2
----
Alice Bob

# Variable-length cross-table: trace all transfer chains from Alice's accounts to final accounts, then find owner
# Alice -[Owns]-> Checking_A -[Transfer]->+ a2 <-[Owns]- p2
# Chain 1: Alice → Checking_A → Checking_B ← Bob (1 transfer hop)
# Chain 2: Alice → Checking_A → Checking_B → Savings_A ← Alice (2 transfer hops, Savings_A owned by Alice)
query TTT
SELECT * FROM GRAPH_TABLE (fin_graph MATCH (p1:Person WHERE p1.name = 'Alice')-[:Owns]->(a1:Account)-[:Transfer]->+(a2:Account)<-[:Owns]-(p2:Person) COLUMNS (a1.acct_name AS from_acct, a2.acct_name AS to_acct, p2.name AS owner)) ORDER BY 1, 2
----
Checking_A Checking_B Bob
Checking_A Savings_A Alice

# Cross-table with multiple vertex types: Person -[Knows]-> Person -[LivesIn]-> City (using mh_graph)
# Already tested as 2-hop above, now test variable-length Knows then LivesIn
# Alice knows Bob, Carol; Bob knows Carol
# Knows ->+ : Alice→Bob (depth 1), Alice→Carol (depth 1), Alice→Bob→Carol (depth 2)
# Then LivesIn: Bob→SF, Carol→NYC (Carol appears twice: depth-1 and depth-2 paths)
query TTT
SELECT * FROM GRAPH_TABLE (mh_graph MATCH (a:Person WHERE a.name = 'Alice')-[:Knows]->+(b:Person)-[:LivesIn]->(c:City) COLUMNS (a.name AS person, b.name AS friend, c.city AS city)) ORDER BY 2, 3
----
Alice Bob SF
Alice Carol NYC
Alice Carol NYC
