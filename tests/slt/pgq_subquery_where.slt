# SQL/PGQ: Subqueries in WHERE filters

# ===================================================================
# Setup
# ===================================================================

statement ok
CREATE TABLE sq_persons (id INTEGER, name VARCHAR, active INTEGER)

statement ok
INSERT INTO sq_persons VALUES (0, 'Alice', 1), (1, 'Bob', 0), (2, 'Carol', 1), (3, 'Dave', 1)

statement ok
CREATE TABLE sq_knows (src INTEGER, dst INTEGER)

statement ok
INSERT INTO sq_knows VALUES (0, 1), (0, 2), (1, 3), (2, 3)

statement ok
CREATE TABLE sq_active_ids (id INTEGER)

statement ok
INSERT INTO sq_active_ids VALUES (0), (2), (3)

statement ok
CREATE PROPERTY GRAPH sq_graph VERTEX TABLES (sq_persons LABEL Person) EDGE TABLES (sq_knows SOURCE KEY (src) REFERENCES sq_persons (id) DESTINATION KEY (dst) REFERENCES sq_persons (id) LABEL Knows)

# ===================================================================
# IN (SELECT ...) subquery
# ===================================================================

query TT
SELECT * FROM GRAPH_TABLE (sq_graph MATCH (a:Person WHERE a.id IN (SELECT id FROM sq_active_ids))-[e:Knows]->(b:Person) COLUMNS (a.name AS src, b.name AS dst)) ORDER BY src, dst
----
Alice Bob
Alice Carol
Carol Dave

# ===================================================================
# NOT IN (SELECT ...) subquery
# ===================================================================

query TT
SELECT * FROM GRAPH_TABLE (sq_graph MATCH (a:Person WHERE a.id NOT IN (SELECT id FROM sq_active_ids))-[e:Knows]->(b:Person) COLUMNS (a.name AS src, b.name AS dst)) ORDER BY src, dst
----
Bob Dave

# ===================================================================
# IN (SELECT ...) with empty result
# ===================================================================

query TT
SELECT * FROM GRAPH_TABLE (sq_graph MATCH (a:Person WHERE a.id IN (SELECT id FROM sq_active_ids WHERE id > 100))-[e:Knows]->(b:Person) COLUMNS (a.name AS src, b.name AS dst))
----

# ===================================================================
# Cleanup
# ===================================================================

statement ok
DROP TABLE sq_persons

statement ok
DROP TABLE sq_knows

statement ok
DROP TABLE sq_active_ids
