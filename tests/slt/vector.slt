# Vector similarity functions
#
# NOTE: Positive tests for COSINE_SIMILARITY, EUCLIDEAN_DISTANCE, and KNN
# cannot be written in SLT because embedding columns (TD_F32) can only be
# created via the Rust API (Table::create_embedding_column). Positive
# coverage is provided by the Rust integration tests in tests/engine_api.rs:
#   - vector_cosine_similarity
#   - vector_euclidean_distance
#   - vector_knn
#
# The tests below validate SQL syntax parsing and error handling.

# Setup: create a table
statement ok
CREATE TABLE docs (id INTEGER, name VARCHAR)

statement ok
INSERT INTO docs VALUES (0, 'math'), (1, 'science'), (2, 'art')

# Test: COSINE_SIMILARITY rejects wrong number of arguments
statement error
SELECT COSINE_SIMILARITY() FROM docs

# Test: EUCLIDEAN_DISTANCE rejects wrong number of arguments
statement error
SELECT EUCLIDEAN_DISTANCE() FROM docs

# Test: COSINE_SIMILARITY rejects non-array second argument
statement error
SELECT COSINE_SIMILARITY(id, 42) FROM docs

# Test: EUCLIDEAN_DISTANCE rejects non-array second argument
statement error
SELECT EUCLIDEAN_DISTANCE(id, 42) FROM docs

# Test: COSINE_SIMILARITY rejects empty array
statement error
SELECT COSINE_SIMILARITY(id, ARRAY[]) FROM docs

# Test: EUCLIDEAN_DISTANCE rejects empty array
statement error
SELECT EUCLIDEAN_DISTANCE(id, ARRAY[]) FROM docs

# ---------------------------------------------------------------------------
# CREATE VECTOR INDEX / DROP VECTOR INDEX
# ---------------------------------------------------------------------------
#
# NOTE: Positive CREATE VECTOR INDEX tests require embedding columns which
# can only be created via the Rust API. Positive coverage is provided by
# the Rust integration tests in tests/engine_api.rs.
#
# The tests below validate SQL syntax parsing and error handling.

# Test: CREATE VECTOR INDEX on non-existent table
statement error
CREATE VECTOR INDEX idx ON nonexistent(col)

# Test: CREATE VECTOR INDEX on non-embedding column
statement error
CREATE VECTOR INDEX idx ON docs(name)

# Test: DROP VECTOR INDEX on non-existent index
statement error
DROP VECTOR INDEX nonexistent

# Test: DROP VECTOR INDEX IF EXISTS on non-existent index (no error)
statement ok
DROP VECTOR INDEX IF EXISTS nonexistent

# Test: CREATE VECTOR INDEX with invalid HNSW parameter
statement error
CREATE VECTOR INDEX idx ON docs(name) USING HNSW(INVALID_PARAM=42)
