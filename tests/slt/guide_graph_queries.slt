# SQL examples from docs/guides/graph-queries.html
# "Graph Queries with SQL/PGQ: Finding Patterns in Connected Data"

# ===== Building the Dataset =====

statement ok
CREATE TABLE persons (id INTEGER, name VARCHAR, risk_score REAL, country VARCHAR)

statement ok
INSERT INTO persons VALUES (1, 'Alice Yang', 0.1, 'US'), (2, 'Bob Petrov', 0.3, 'UK'), (3, 'Carol Santos', 0.8, 'BR'), (4, 'Dave Mueller', 0.2, 'DE'), (5, 'Eve Nakamura', 0.9, 'JP'), (6, 'Frank Osei', 0.4, 'GH'), (7, 'Grace Park', 0.1, 'KR'), (8, 'Hector Ruiz', 0.7, 'MX')

statement ok
