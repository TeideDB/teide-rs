INSERT INTO transfers VALUES (1, 101, 103, 15000.0, '2024-01-10', 'consulting'), (2, 103, 104, 9500.0, '2024-01-12', 'payment'), (3, 104, 107, 9000.0, '2024-01-14', 'services'), (4, 107, 101, 8500.0, '2024-01-16', 'refund'), (5, 102, 106, 25000.0, '2024-02-01', 'investment'), (6, 106, 109, 12000.0, '2024-02-05', 'transfer'), (7, 109, 110, 5000.0, '2024-02-10', 'savings'), (8, 105, 108, 4900.0, '2024-03-01', 'split-1'), (9, 105, 109, 4800.0, '2024-03-01', 'split-2'), (10, 105, 111, 4700.0, '2024-03-01', 'split-3'), (11, 110, 102, 30000.0, '2024-03-15', 'quarterly'), (12, 103, 106, 7000.0, '2024-04-01', 'payment'), (13, 106, 104, 3000.0, '2024-04-05', 'fee'), (14, 108, 103, 2500.0, '2024-04-10', 'return'), (15, 111, 104, 4500.0, '2024-04-15', 'payment')

# Sanity checks
query I
SELECT COUNT(*) AS n_persons FROM persons
----
8

query I
SELECT COUNT(*) AS n_accounts FROM accounts
----
11

query I
SELECT COUNT(*) AS n_transfers FROM transfers
----
15

# ===== Creating a Property Graph =====

statement ok
CREATE PROPERTY GRAPH financial VERTEX TABLES (persons KEY (id), accounts KEY (id)) EDGE TABLES (owns SOURCE KEY (person_id) REFERENCES persons (id) DESTINATION KEY (account_id) REFERENCES accounts (id), transfers SOURCE KEY (src_account) REFERENCES accounts (id) DESTINATION KEY (dst_account) REFERENCES accounts (id))

# ===== First MATCH: Direct Transfers =====

# All transfers between accounts
query III rowsort
SELECT src, dst, amount FROM GRAPH_TABLE (financial MATCH (a:accounts)-[t:transfers]->(b:accounts) COLUMNS (a.id AS src, b.id AS dst, t.amount AS amount))
----
101 103 15000
102 106 25000
103 104 9500
103 106 7000
104 107 9000
105 108 4900
105 109 4800
105 111 4700
106 104 3000
106 109 12000
107 101 8500
108 103 2500
109 110 5000
110 102 30000
111 104 4500

# Large transfers only (WHERE inside MATCH on edge property)
query IIIT rowsort
SELECT src, dst, amount, memo FROM GRAPH_TABLE (financial MATCH (a:accounts)-[t:transfers WHERE t.amount > 10000]->(b:accounts) COLUMNS (a.id AS src, b.id AS dst, t.amount AS amount, t.memo AS memo))
----
101 103 15000 consulting
102 106 25000 investment
106 109 12000 transfer
110 102 30000 quarterly

# ===== Who Owns What? =====

query TIT rowsort
SELECT person_name, acct, acct_type FROM GRAPH_TABLE (financial MATCH (p:persons)-[o:owns]->(a:accounts) COLUMNS (p.name AS person_name, a.id AS acct, a.account_type AS acct_type))
----
Alice Yang 101 checking
Alice Yang 102 savings
Bob Petrov 103 checking
Carol Santos 104 checking
Carol Santos 105 business
Dave Mueller 106 checking
Eve Nakamura 107 business
Eve Nakamura 108 checking
Frank Osei 109 checking
Grace Park 110 savings
Hector Ruiz 111 checking

# ===== Following the Money: Multi-Hop Paths =====

# Trace all paths of 1 to 3 hops starting from account 101
query III rowsort
SELECT src, dst, hops FROM GRAPH_TABLE (financial MATCH (a:accounts WHERE a.id = 101)-[t:transfers]->{1,3}(b:accounts) COLUMNS (a.id AS src, b.id AS dst, path_length(a, b) AS hops))
----
101 103 1
101 104 2
101 106 2
101 107 3
101 109 3

# ANY SHORTEST from account 101 to account 107
# ANY SHORTEST returns one row per node on the path; use DISTINCT to get summary
query III
SELECT DISTINCT src, dst, hops FROM GRAPH_TABLE (financial MATCH p = ANY SHORTEST (a:accounts WHERE a.id = 101)-[t:transfers]->{1,5}(b:accounts WHERE b.id = 107) COLUMNS (a.id AS src, b.id AS dst, path_length(p) AS hops))
----
101 107 3

# ===== Detecting Circular Flows =====

# Check if account 101 has circular flows (2-5 hops back to itself)
# Use same variable (a) for start and end to detect cycles
query III rowsort
SELECT src, dst, hops FROM GRAPH_TABLE (financial MATCH (a:accounts WHERE a.id = 101)-[t:transfers]->{2,5}(a:accounts) COLUMNS (a.id AS src, a.id AS dst, path_length(a, a) AS hops))
----
101 101 4
101 101 5

# CHEAPEST path from account 101 to account 107 (non-cycle Dijkstra)
# Note: The guide shows CHEAPEST for cycles (src==dst), but Dijkstra returns 0 for
# same-node queries. We test a non-cycle CHEAPEST path instead.
query IIR
SELECT src, dst, total_cost FROM GRAPH_TABLE (financial MATCH p = ANY SHORTEST (a:accounts WHERE a.id = 101)-[t:transfers COST t.amount]->+(b:accounts WHERE b.id = 107) COLUMNS (a.id AS src, b.id AS dst, path_cost(p) AS total_cost))
----
101 107 34000.0

# ===== Smurfing Detection =====

# Transfers from account 105 (smurfing pattern)
query IIIT rowsort
SELECT src, dst, amount, memo FROM GRAPH_TABLE (financial MATCH (a:accounts WHERE a.id = 105)-[t:transfers]->(b:accounts) COLUMNS (a.id AS src, b.id AS dst, t.amount AS amount, t.memo AS memo))
----
105 108 4900 split-1
105 109 4800 split-2
105 111 4700 split-3

# ===== Smurfing Detection with GROUP BY =====
# Find accounts that sent to 3+ distinct destinations on the same day
# Note: The guide wraps GRAPH_TABLE in a subquery with GROUP BY and outer WHERE.
# TeideDB supports this pattern.
query I
SELECT COUNT(*) FROM (SELECT src, transfer_dt, COUNT(*) AS n_destinations, SUM(amount) AS total_amount FROM GRAPH_TABLE (financial MATCH (a:accounts)-[t:transfers]->(b:accounts) COLUMNS (a.id AS src, b.id AS dst, t.amount AS amount, t.transfer_date AS transfer_dt)) GROUP BY src, transfer_dt) WHERE n_destinations >= 3
----
1

# ===== Graph Algorithms =====
# Note: Algorithm functions require a graph with a single edge label.
# The guide's 'financial' graph has two edge labels (owns, transfers),
# so we create a transfer-only graph for algorithm queries.

statement ok
CREATE PROPERTY GRAPH transfer_net VERTEX TABLES (accounts KEY (id)) EDGE TABLES (transfers SOURCE KEY (src_account) REFERENCES accounts (id) DESTINATION KEY (dst_account) REFERENCES accounts (id))

# PageRank on the transfer network — verify all accounts get positive rank
query I
SELECT COUNT(*) FROM GRAPH_TABLE (transfer_net MATCH (a:accounts) COLUMNS (PAGERANK(transfer_net, a) AS rank)) WHERE rank > 0
----
11

# Community detection — all community IDs should be non-negative
query I
SELECT COUNT(*) FROM GRAPH_TABLE (transfer_net MATCH (a:accounts) COLUMNS (COMMUNITY(transfer_net, a) AS community)) WHERE community >= 0
----
11

# Connected components — all accounts in a single connected component
query I
SELECT COUNT(DISTINCT comp) FROM GRAPH_TABLE (transfer_net MATCH (a:accounts) COLUMNS (COMPONENT(transfer_net, a) AS comp))
----
1

statement ok
DROP PROPERTY GRAPH transfer_net

# ===== Cleanup =====

statement ok
DROP PROPERTY GRAPH financial

statement ok
DROP TABLE transfers

statement ok
DROP TABLE owns

statement ok
DROP TABLE accounts

statement ok
DROP TABLE persons
